# Google Cloud Project Configuration
GOOGLE_GENAI_USE_VERTEXAI="True"
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
ADK_MODEL="gemini-2.5-flash"

# Google Calendar OAuth 2.0 Credentials
# Get these from Google Cloud Console > Credentials
# Create OAuth 2.0 Client ID (Web application type)
GOOGLE_CALENDAR_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="your-client-secret"

# Google Places API Key
# Create API key from Google Cloud Console:
# 1. Enable Places API (New)
# 2. Go to Credentials > Create Credentials > API Key
# 3. Restrict the key to Places API for security
GOOGLE_PLACES_API_KEY="your-places-api-key-here"
